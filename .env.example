# ---------------------------------------------------------------------------
# Property Registry — environment variables
# Copy this file to `.env` and fill in the values.
# The app boots with sensible dev fallbacks; features below activate when set.
# ---------------------------------------------------------------------------

# Database (PostgreSQL) — required
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_registry?schema=public"

# App URL — used to build absolute URLs (Stripe redirects, downloads)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Clerk Authentication ----
# Leave blank to run in "auth-disabled" dev mode (public pages render;
# dashboard/admin fall back to a local dev user). Set these to enable real auth.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Comma-separated list of admin emails (granted admin role on first sign-in).
ADMIN_EMAILS="admin@example.com"

# ---- Stripe ----
# Leave blank to run checkout in "demo mode" (orders are marked paid instantly).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---- File storage ----
# STORAGE_DRIVER=local (default) stores under ./storage
# STORAGE_DRIVER=s3 uses AWS S3 (fill AWS_* + S3_BUCKET below)
STORAGE_DRIVER="local"
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""
