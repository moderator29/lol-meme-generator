# Supabase project dashboard under Settings then API then Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase project dashboard under Settings then API then anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project dashboard under Settings then API then service_role secret key
# Used in server side admin operations that bypass RLS. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Console, enable Cloud Translation API, create an API key under Credentials
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=

# Free geolocation API, no key required. Always set to this exact value.
NEXT_PUBLIC_IPAPI_URL=https://ipapi.co/json/
