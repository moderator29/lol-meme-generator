// Property Registry — Prisma schema
// Tables: users, properties, property_images, documents, orders

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PropertyType {
  DETACHED
  SEMI_DETACHED
  TERRACED
  FLAT
  BUNGALOW
  COMMERCIAL
  LAND
}

enum DocumentType {
  TITLE_REGISTER
  TITLE_PLAN
  FLOOD_RISK
  ENERGY_PERFORMANCE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id            String   @id @default(cuid())
  clerkId       String?  @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  searches      SearchLog[]

  @@map("users")
}

model Property {
  id             String       @id @default(cuid())
  registryNumber String       @unique
  addressLine1   String
  addressLine2   String?
  city           String
  postcode       String
  propertyType   PropertyType @default(DETACHED)
  tenure         String       @default("Freehold")
  estimatedValue Int // stored in whole GBP
  bedrooms       Int?
  bathrooms      Int?
  description    String       @default("")
  published      Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  images         PropertyImage[]
  documents      Document[]
  orders         Order[]

  @@index([postcode])
  @@index([city])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Document {
  id           String       @id @default(cuid())
  propertyId   String
  type         DocumentType @default(TITLE_REGISTER)
  title        String
  description  String       @default("")
  // storage key (local path or S3 object key) — never a public URL
  storageKey   String
  priceInPence Int          @default(300) // £3.00 default, like official title copies
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([propertyId])
  @@map("documents")
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  propertyId            String
  documentId            String
  status                OrderStatus @default(PENDING)
  amountInPence         Int
  currency              String      @default("gbp")
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([propertyId])
  @@map("orders")
}

// Not one of the "core five" tables from the spec, but required for the
// "previous searches" dashboard feature. Kept intentionally minimal.
model SearchLog {
  id        String   @id @default(cuid())
  userId    String
  query     String
  results   Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("search_logs")
}
